{
  "name": "yantai-radar-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-dev-with-lan-ip.ps1",
    "build": "next build",
    "start": "pnpm dlx serve out -l 4173",
    "preview": "pnpm dlx serve out -l 4173",
    "lint": "eslint",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "sales-intel:build": "node scripts/build-sales-intel.mjs",
    "api:start": "node server/index.mjs --host 0.0.0.0",
    "api:dev": "node --watch server/index.mjs --host 0.0.0.0",
    "boss:browser": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-boss-chrome.ps1",
    "boss:collect": "node scripts/collect-boss-recruitment-leads.mjs",
    "boss:export-session": "node scripts/export-boss-session.mjs",
    "boss:sync-session": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/sync-boss-session-to-server.ps1",
    "51job:collect": "node scripts/collect-51job-recruitment-leads.mjs",
    "zhaopin:browser": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-zhaopin-chrome.ps1",
    "zhaopin:collect": "node scripts/collect-zhaopin-recruitment-leads.mjs",
    "zhaopin:export-session": "node scripts/export-zhaopin-session.mjs",
    "zhaopin:sync-session": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/sync-zhaopin-session-to-server.ps1",
    "xiaohongshu:browser": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-xiaohongshu-chrome.ps1",
    "xiaohongshu:collect": "node scripts/collect-xiaohongshu-sales-signals.mjs",
    "xiaohongshu:export-session": "node scripts/export-xiaohongshu-session.mjs",
    "xiaohongshu:sync-session": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/sync-xiaohongshu-session-to-server.ps1",
    "recruitment:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-local-recruitment-automation.ps1",
    "recruitment:task:install": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/install-local-recruitment-task.ps1"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "china-division": "2.7.0",
    "china-map-geojson": "1.0.4",
    "echarts": "6.0.0",
    "echarts-for-react": "3.0.6",
    "fastify": "^5.8.4",
    "i18next": "^26.0.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "leaflet": "^1.9.4",
    "next": "16.2.3",
    "pinyin-pro": "^3.28.1",
    "rc-cascader": "^3.34.0",
    "react": "19.2.4",
    "react-country-flag": "^3.1.0",
    "react-dom": "19.2.4",
    "react-i18next": "^17.0.2",
    "react-icons": "^5.6.0",
    "react-leaflet": "^5.0.0",
    "react-select": "^5.10.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5"
  }
